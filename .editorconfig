# Editor configuration, see https://editorconfig.org
root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = lf

[*.html]
indent_size = 2
max_line_length = off

[*.ts]
indent_size = 2
quote_type = single

[*.md]
max_line_length = off
indent_size = 4
trim_trailing_whitespace = false

[*.yml]
max_line_length = off

[*.py]
indent_size = 4
quote_type = single
