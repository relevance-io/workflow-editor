{
  "name": "@relevance/workflow-editor",
  "version": "1.0.2",
  "description": "",
  "homepage": "https://github.com/relevance-io/workflow-editor#readme",
  "bugs": {
    "url": "https://github.com/relevance-io/workflow-editor/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/relevance-io/workflow-editor.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "./index.cjs.js",
  "module": "./index.es.js",
  "types": "./index.d.ts",
  "*": {
    "angular": [
      "./angular/index.d.ts"
    ]
  },
  "typesVersions": {
    "*": {
      "angular": [
        "./angular/types/relevance-workflow-editor-angular.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.es.js",
      "require": "./index.cjs.js"
    },
    "./angular": {
      "types": "./angular/types/relevance-workflow-editor-angular.d.ts",
      "default": "./angular/fesm2022/relevance-workflow-editor-angular.mjs"
    },
    "./style": "./index.css"
  },
  "scripts": {
    "start": "vite",
    "clean": "rm -Rf dist/",
    "build:app": "vite build",
    "build:lib": "BUILD_TARGET=lib vite build && tsc --project tsconfig.lib.json && cp -f src/index.css dist/ && cp -f package.json dist/",
    "build:angular": "cd lib/angular/ && npm run build",
    "build": "npm run build:lib && npm run build:app && npm run build:angular"
  },
  "dependencies": {
    "dagre": "^0.8.5",
    "jointjs": "^3.7.7"
  },
  "devDependencies": {
    "@types/backbone": "^1.4.15",
    "@types/dagre": "^0.7.3",
    "@types/node": "^25.5.0",
    "terser": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.3",
    "vite-plugin-singlefile": "^2.0.0"
  }
}
