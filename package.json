{
  "name": "@relevance/workflow-editor",
  "version": "1.0.0",
  "description": "",
  "homepage": "https://github.com/relevance-io/workflow-editor#readme",
  "bugs": {
    "url": "https://github.com/relevance-io/workflow-editor/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/relevance-io/workflow-editor.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "./index.cjs.js",
  "module": "./index.es.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.es.js",
      "require": "./index.cjs.js"
    },
    "./style": "./index.css"
  },
  "scripts": {
    "dev": "vite",
    "clean": "rm -Rf dist/",
    "build:app": "vite build",
    "build:lib": "BUILD_TARGET=lib vite build && tsc --project tsconfig.lib.json && cp -f src/index.css dist/",
    "build": "npm run build:lib && npm run build:app && cp -f package.json dist/",
    "preview": "vite preview"
  },
  "dependencies": {
    "dagre": "^0.8.5",
    "jointjs": "^3.7.7"
  },
  "devDependencies": {
    "@types/backbone": "^1.4.15",
    "@types/dagre": "^0.7.3",
    "@types/node": "^25.5.0",
    "terser": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.3",
    "vite-plugin-singlefile": "^2.0.0"
  }
}